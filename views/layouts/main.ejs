<!DOCTYPE html>
<html lang="en" class="<%= typeof darkMode !== 'undefined' && darkMode ? 'dark' : '' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <%# Page Title %>
  <title><%= typeof title !== 'undefined' && title ? title + ' - ' : '' %><%= siteSettings.siteName %></title>

  <%# Meta Description %>
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : (siteSettings.seoDefaults.description || siteSettings.siteDescription || '') %>">

  <%# Meta Keywords %>
  <% if (typeof keywords !== 'undefined' && keywords) { %>
    <meta name="keywords" content="<%= keywords %>">
  <% } else if (siteSettings.seoDefaults.keywords) { %>
    <meta name="keywords" content="<%= siteSettings.seoDefaults.keywords %>">
  <% } %>

  <%# Canonical URL %>
  <% if (typeof canonicalUrl !== 'undefined' && canonicalUrl) { %>
    <link rel="canonical" href="<%= canonicalUrl %>">
  <% } %>

  <%# Pagination rel=next / rel=prev for SEO %>
  <% if (typeof paginationPrevUrl !== 'undefined' && paginationPrevUrl) { %>
    <link rel="prev" href="<%= paginationPrevUrl %>">
  <% } %>
  <% if (typeof paginationNextUrl !== 'undefined' && paginationNextUrl) { %>
    <link rel="next" href="<%= paginationNextUrl %>">
  <% } %>

  <%# Robots meta %>
  <% if (typeof noindex !== 'undefined' && noindex) { %>
    <meta name="robots" content="noindex, nofollow">
  <% } else { %>
    <meta name="robots" content="index, follow">
  <% } %>

  <%# Open Graph Tags %>
  <meta property="og:type" content="<%= typeof ogType !== 'undefined' && ogType ? ogType : 'website' %>">
  <meta property="og:title" content="<%= typeof ogTitle !== 'undefined' && ogTitle ? ogTitle : (typeof title !== 'undefined' && title ? title + ' - ' + siteSettings.siteName : siteSettings.seoDefaults.title || siteSettings.siteName) %>">
  <meta property="og:description" content="<%= typeof ogDescription !== 'undefined' && ogDescription ? ogDescription : (typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : (siteSettings.seoDefaults.description || siteSettings.siteDescription || '')) %>">
  <% if (typeof canonicalUrl !== 'undefined' && canonicalUrl) { %>
    <meta property="og:url" content="<%= canonicalUrl %>">
  <% } %>
  <meta property="og:site_name" content="<%= siteSettings.siteName %>">
  <%
    var _ogImg = '';
    if (typeof ogImage !== 'undefined' && ogImage) {
      _ogImg = ogImage;
    } else if (siteSettings.logo) {
      _ogImg = siteSettings.logo.startsWith('http') ? siteSettings.logo : (typeof baseUrl !== 'undefined' ? baseUrl : '') + siteSettings.logo;
    } else if (typeof baseUrl !== 'undefined') {
      _ogImg = baseUrl + '/images/og-default.svg';
    }
  %>
  <% if (_ogImg) { %>
    <meta property="og:image" content="<%= _ogImg %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
  <% } %>

  <%# Twitter Card Tags %>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= typeof ogTitle !== 'undefined' && ogTitle ? ogTitle : (typeof title !== 'undefined' && title ? title + ' - ' + siteSettings.siteName : siteSettings.seoDefaults.title || siteSettings.siteName) %>">
  <meta name="twitter:description" content="<%= typeof ogDescription !== 'undefined' && ogDescription ? ogDescription : (typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : (siteSettings.seoDefaults.description || siteSettings.siteDescription || '')) %>">
  <% if (_ogImg) { %>
    <meta name="twitter:image" content="<%= _ogImg %>">
  <% } %>

  <%# Favicon %>
  <% if (siteSettings.favicon) { %>
    <link rel="icon" href="<%= siteSettings.favicon %>" type="image/x-icon">
    <link rel="shortcut icon" href="<%= siteSettings.favicon %>">
  <% } %>

  <%# Stylesheets %>
  <link rel="stylesheet" href="/css/output.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <%# JSON-LD Structured Data %>
  <% if (typeof structuredData !== 'undefined' && structuredData) { %>
    <% if (Array.isArray(structuredData)) { %>
      <% structuredData.forEach(function(schema) { %>
        <script type="application/ld+json"><%- JSON.stringify(schema) %></script>
      <% }) %>
    <% } else { %>
      <script type="application/ld+json"><%- JSON.stringify(structuredData) %></script>
    <% } %>
  <% } %>

  <style>
    [x-cloak] { display: none !important; }
  </style>
</head>
<body class="min-h-screen flex flex-col">
  <%- include('../partials/header') %>

  <main class="flex-1">
    <% if (flash.success && flash.success.length) { %>
      <div class="max-w-7xl mx-auto px-4 mt-4">
        <div class="bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-300 px-4 py-3 rounded-lg flex justify-between items-center">
          <span><%= flash.success[0] %></span>
          <button onclick="this.parentElement.remove()" class="text-green-500 hover:text-green-700">&times;</button>
        </div>
      </div>
    <% } %>
    <% if (flash.error && flash.error.length) { %>
      <div class="max-w-7xl mx-auto px-4 mt-4">
        <div class="bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 px-4 py-3 rounded-lg flex justify-between items-center">
          <span><%= flash.error[0] %></span>
          <button onclick="this.parentElement.remove()" class="text-red-500 hover:text-red-700">&times;</button>
        </div>
      </div>
    <% } %>

    <%- body %>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/chat-widget') %>
  <script src="/js/main.js"></script>
</body>
</html>
