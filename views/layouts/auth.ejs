<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %><%= siteSettings.siteName %></title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="stylesheet" href="/css/output.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-gray-50 dark:bg-gray-900 min-h-screen flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <a href="/" class="text-3xl font-bold text-primary-500"><%= siteSettings.siteName %></a>
      <p class="text-gray-500 dark:text-gray-400 mt-2"><%= siteSettings.siteDescription %></p>
    </div>

    <% if (flash.success && flash.success.length) { %>
      <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-4">
        <%= flash.success[0] %>
      </div>
    <% } %>
    <% if (flash.error && flash.error.length) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4">
        <%= flash.error[0] %>
      </div>
    <% } %>

    <div class="card p-6">
      <%- body %>
    </div>
  </div>
  <script src="/js/main.js"></script>
</body>
</html>
