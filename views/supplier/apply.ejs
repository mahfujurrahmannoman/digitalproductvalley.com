<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="card p-6">
    <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-200 mb-6">Become a Supplier</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6">Join our marketplace and start selling digital accounts. Fill out the application below and our team will review it.</p>
    <form action="/supplier/apply" method="POST">
      <div class="mb-4">
        <label class="label">Company / Brand Name</label>
        <input type="text" name="companyName" class="input-field" required placeholder="Your business name">
      </div>
      <div class="mb-4">
        <label class="label">Description</label>
        <textarea name="description" class="input-field" rows="4" required placeholder="Tell us about your business and what accounts you sell"></textarea>
      </div>
      <button type="submit" class="btn-primary w-full">Submit Application</button>
    </form>
  </div>
</div>
