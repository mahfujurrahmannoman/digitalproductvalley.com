<div class="max-w-3xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-200 mb-6"><%= product ? 'Edit Product' : 'New Product' %></h1>

  <form action="<%= product ? '/supplier/products/' + product._id : '/supplier/products' %>" method="POST" enctype="multipart/form-data" class="card p-6 space-y-4">
    <div>
      <label class="label">Title *</label>
      <input type="text" name="title" class="input-field" required value="<%= product ? product.title : '' %>">
    </div>
    <div>
      <label class="label">Short Description</label>
      <input type="text" name="shortDescription" class="input-field" value="<%= product ? product.shortDescription || '' : '' %>">
    </div>
    <div>
      <label class="label">Description *</label>
      <textarea name="description" class="input-field" rows="4" required><%= product ? product.description : '' %></textarea>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="label">Category *</label>
        <select name="category" class="input-field" required>
          <option value="">Select Category</option>
          <% const renderCats = (cats, prefix = '') => { cats.forEach(c => { %>
            <option value="<%= c._id %>" <%= product && product.category && product.category.toString() === c._id.toString() ? 'selected' : '' %>><%= prefix %><%= c.name %></option>
            <% if (c.children) renderCats(c.children, prefix + '— '); }); }; renderCats(categories); %>
        </select>
      </div>
      <div>
        <label class="label">Price (USD) *</label>
        <input type="number" name="price" class="input-field" step="0.01" min="0.01" required value="<%= product ? product.price : '' %>">
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="label">Min Quantity</label>
        <input type="number" name="minQuantity" class="input-field" min="1" value="<%= product ? product.minQuantity : 1 %>">
      </div>
      <div>
        <label class="label">Max Quantity</label>
        <input type="number" name="maxQuantity" class="input-field" min="1" value="<%= product ? product.maxQuantity : 100 %>">
      </div>
      <div>
        <label class="label">Delivery Type</label>
        <select name="deliveryType" class="input-field">
          <option value="auto" <%= product && product.deliveryType === 'auto' ? 'selected' : '' %>>Auto Delivery</option>
          <option value="manual" <%= product && product.deliveryType === 'manual' ? 'selected' : '' %>>Manual Delivery</option>
        </select>
      </div>
    </div>

    <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200 pt-4 border-t border-gray-200 dark:border-gray-700">Account Details</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="label">Region</label>
        <input type="text" name="region" class="input-field" placeholder="e.g. USA, Global" value="<%= product?.accountDetails?.region || '' %>">
      </div>
      <div>
        <label class="label">Account Age</label>
        <input type="text" name="accountAge" class="input-field" placeholder="e.g. 2020-2023" value="<%= product?.accountDetails?.accountAge || '' %>">
      </div>
      <div>
        <label class="label">Verification</label>
        <input type="text" name="verification" class="input-field" placeholder="e.g. Phone verified" value="<%= product?.accountDetails?.verification || '' %>">
      </div>
      <div>
        <label class="label">Format</label>
        <input type="text" name="format" class="input-field" placeholder="e.g. email:password" value="<%= product?.accountDetails?.format || '' %>">
      </div>
    </div>
    <div>
      <label class="label">Features (comma-separated)</label>
      <input type="text" name="features" class="input-field" placeholder="e.g. 2FA enabled, Profile picture" value="<%= product?.accountDetails?.features?.join(', ') || '' %>">
    </div>

    <div>
      <label class="label">Product Image</label>
      <input type="file" name="image" class="input-field" accept="image/*">
      <% if (product && product.image) { %>
        <img src="<%= product.image %>" class="w-20 h-20 object-cover rounded mt-2">
      <% } %>
    </div>

    <% if (!product) { %>
      <div>
        <label class="label">Account Stock (one per line)</label>
        <textarea name="stockData" class="input-field font-mono text-sm" rows="6" placeholder="email1:password1&#10;email2:password2&#10;email3:password3"></textarea>
        <p class="text-xs text-gray-500 mt-1">Enter account credentials, one per line. They will be encrypted and stored securely.</p>
      </div>
    <% } %>

    <div class="flex gap-3 pt-4">
      <button type="submit" class="btn-primary"><%= product ? 'Update Product' : 'Create Product' %></button>
      <a href="/supplier/products" class="btn-secondary">Cancel</a>
    </div>
  </form>
</div>
