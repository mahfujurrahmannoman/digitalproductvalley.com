<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-200">My Products</h1>
    <a href="/supplier/products/new" class="btn-primary"><i class="fas fa-plus mr-2"></i>Add Product</a>
  </div>

  <% if (products.length === 0) { %>
    <div class="card p-8 text-center">
      <i class="fas fa-box text-4xl text-gray-300 dark:text-gray-600 mb-4"></i>
      <p class="text-gray-500 dark:text-gray-400">You haven't added any products yet</p>
      <a href="/supplier/products/new" class="btn-primary mt-4 inline-block">Create Your First Product</a>
    </div>
  <% } else { %>
    <div class="table-container card">
      <table>
        <thead><tr><th>Product</th><th>Category</th><th>Price</th><th>Stock</th><th>Sold</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% products.forEach(p => { %>
            <tr>
              <td class="font-medium text-gray-800 dark:text-gray-200"><%= p.title %></td>
              <td><%= p.category?.name || '-' %></td>
              <td><%= helpers.formatPrice(p.price) %></td>
              <td><span class="<%= p.stockCount > 0 ? 'text-green-600' : 'text-red-600' %>"><%= p.stockCount %></span></td>
              <td><%= p.totalSold %></td>
              <td><span class="badge-<%= p.isActive ? 'success' : 'danger' %>"><%= p.isActive ? 'Active' : 'Inactive' %></span></td>
              <td>
                <div class="flex gap-2">
                  <a href="/supplier/products/<%= p._id %>/edit" class="text-blue-500 hover:text-blue-700 text-sm">Edit</a>
                  <a href="/supplier/products/<%= p._id %>/stock" class="text-primary-500 hover:text-primary-700 text-sm">Stock</a>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <%- include('../partials/pagination') %>
  <% } %>
</div>
