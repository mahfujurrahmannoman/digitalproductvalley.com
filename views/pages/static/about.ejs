<!-- Hero Section -->
<div class="bg-primary-500 py-12">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h1 class="text-3xl md:text-5xl font-bold text-white mb-3">About Us</h1>
    <p class="text-primary-100 text-lg">Your trusted marketplace for premium digital accounts</p>
  </div>
</div>

<div class="max-w-4xl mx-auto px-4 py-10">
  <!-- Who We Are -->
  <div class="card p-8 mb-8">
    <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-4">Who We Are</h2>
    <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
      <%= siteSettings.siteName %> is a trusted digital accounts marketplace where buyers and sellers connect for premium digital products.
      We provide a secure platform for purchasing verified digital accounts with instant delivery and full support.
    </p>
  </div>

  <!-- Our Mission -->
  <div class="card p-8 mb-8">
    <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-4">Our Mission</h2>
    <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
      Our mission is to create the most reliable and user-friendly marketplace for digital accounts.
      We focus on quality verification, instant delivery, and exceptional customer support to ensure every transaction is smooth and secure.
    </p>
  </div>

  <!-- Why Choose Us -->
  <div class="card p-8 mb-8">
    <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-6">Why Choose Us</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center flex-shrink-0">
          <i class="fas fa-bolt text-primary-500 text-lg"></i>
        </div>
        <div>
          <h3 class="font-semibold text-gray-800 dark:text-white mb-1">Instant Delivery</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400">Automated systems deliver your accounts within seconds of payment.</p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center flex-shrink-0">
          <i class="fas fa-shield-alt text-primary-500 text-lg"></i>
        </div>
        <div>
          <h3 class="font-semibold text-gray-800 dark:text-white mb-1">Verified Quality</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400">Every account is verified before being listed on our platform.</p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center flex-shrink-0">
          <i class="fas fa-headset text-primary-500 text-lg"></i>
        </div>
        <div>
          <h3 class="font-semibold text-gray-800 dark:text-white mb-1">24/7 Support</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400">Our support team is available around the clock to help you.</p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center flex-shrink-0">
          <i class="fas fa-lock text-primary-500 text-lg"></i>
        </div>
        <div>
          <h3 class="font-semibold text-gray-800 dark:text-white mb-1">Secure Payments</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400">Multiple secure payment options including crypto and mobile banking.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Contact -->
  <div class="card p-8">
    <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-4">Contact Us</h2>
    <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
      Have questions or need help? Reach out to our support team through the
      <a href="/support" class="text-primary-500 hover:text-primary-600 font-medium">support ticket system</a>
      and we will respond as quickly as possible.
    </p>
  </div>
</div>
