<div class="max-w-xl mx-auto px-4 py-24 text-center">
  <div class="w-20 h-20 mx-auto rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center mb-6">
    <i class="fas fa-exclamation-triangle text-3xl text-red-500"></i>
  </div>
  <h1 class="text-3xl font-bold text-gray-800 dark:text-white mb-3">Something Went Wrong</h1>
  <p class="text-gray-500 dark:text-gray-400 mb-8">
    An unexpected error occurred. Please try again later or contact support if the problem persists.
  </p>

  <% if (typeof error !== 'undefined' && error && error.message) { %>
    <div class="card p-4 mb-8 text-left">
      <p class="text-sm font-mono text-red-600 dark:text-red-400"><%= error.message %></p>
      <% if (error.stack && (typeof process !== 'undefined' && process.env.NODE_ENV !== 'production')) { %>
        <pre class="text-xs text-gray-500 dark:text-gray-400 mt-2 overflow-x-auto whitespace-pre-wrap"><%= error.stack %></pre>
      <% } %>
    </div>
  <% } %>

  <div class="flex items-center justify-center gap-4">
    <a href="/" class="btn-primary py-3 px-6">
      <i class="fas fa-home mr-2"></i>Go Home
    </a>
    <button onclick="window.history.back()" class="btn-secondary py-3 px-6">
      <i class="fas fa-arrow-left mr-2"></i>Go Back
    </button>
  </div>
</div>
