<div class="max-w-2xl mx-auto px-4 py-12">
  <!-- Success Header -->
  <div class="text-center mb-8">
    <div class="w-24 h-24 mx-auto rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center mb-4">
      <i class="fas fa-check-circle text-5xl text-green-500"></i>
    </div>
    <h1 class="text-3xl font-bold text-gray-800 dark:text-white mb-2">Order Successful!</h1>
    <p class="text-gray-500 dark:text-gray-400">Thank you for your purchase. Your order has been processed.</p>
  </div>

  <!-- Order Details Card -->
  <div class="card p-6 mb-6">
    <div class="flex items-center justify-between mb-4 pb-4 border-b border-gray-100 dark:border-gray-700/50">
      <h2 class="font-bold text-gray-800 dark:text-white text-lg">Order Details</h2>
      <% if (order.status === 'completed' || order.status === 'delivered') { %>
        <span class="badge-success"><i class="fas fa-check mr-1"></i><%= order.status.replace(/_/g, ' ') %></span>
      <% } else { %>
        <span class="badge-warning"><i class="fas fa-clock mr-1"></i><%= order.status.replace(/_/g, ' ') %></span>
      <% } %>
    </div>

    <div class="space-y-3 text-sm">
      <div class="flex justify-between">
        <span class="text-gray-500 dark:text-gray-400">Order Number</span>
        <span class="font-bold text-primary-500">#<%= order.orderNumber %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-gray-500 dark:text-gray-400">Payment Method</span>
        <span class="font-medium text-gray-800 dark:text-white capitalize"><%= order.paymentMethod %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-gray-500 dark:text-gray-400">Total Amount</span>
        <span class="font-bold text-primary-500"><%= helpers.formatPrice(order.totalAmount) %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-gray-500 dark:text-gray-400">Date</span>
        <span class="font-medium text-gray-800 dark:text-white"><%= helpers.formatDate(order.createdAt) %></span>
      </div>
    </div>
  </div>

  <!-- Order Items -->
  <div class="card p-6 mb-6">
    <h3 class="font-bold text-gray-800 dark:text-white mb-4">Items Purchased</h3>
    <% order.items.forEach(function(item) { %>
      <div class="flex items-center gap-4 py-3 border-b border-gray-100 dark:border-gray-700/50 last:border-0">
        <% if (item.product && item.product.image) { %>
          <img src="<%= item.product.image %>" alt="<%= item.product.title %>" class="w-14 h-14 rounded-lg object-cover border border-gray-200">
        <% } else { %>
          <div class="w-14 h-14 rounded-lg bg-gray-100 dark:bg-gray-700 flex items-center justify-center">
            <i class="fas fa-box text-gray-400"></i>
          </div>
        <% } %>
        <div class="flex-1 min-w-0">
          <p class="font-medium text-gray-800 dark:text-white text-sm truncate">
            <% if (item.product && item.product.slug) { %>
              <a href="/product/<%= item.product.slug %>" class="hover:text-primary-500"><%= item.product.title %></a>
            <% } else { %>
              Product
            <% } %>
          </p>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Qty: <%= item.quantity %></p>
        </div>
        <div class="text-right flex-shrink-0">
          <p class="font-semibold text-gray-800 dark:text-white text-sm"><%= helpers.formatPrice(item.totalPrice) %></p>
          <% if (item.isDelivered) { %>
            <span class="text-xs text-green-500 font-medium"><i class="fas fa-check-circle mr-1"></i>Delivered</span>
          <% } else { %>
            <span class="text-xs text-yellow-500 font-medium"><i class="fas fa-clock mr-1"></i>Processing</span>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>

  <!-- Delivered Account Credentials -->
  <% var deliveredItems = order.items.filter(function(item) { return item.isDelivered && item.deliveredAccounts && item.deliveredAccounts.length > 0; }); %>
  <% if (deliveredItems.length > 0) { %>
    <div class="card p-6 mb-6">
      <h3 class="font-bold text-gray-800 dark:text-white mb-3">
        <i class="fas fa-key text-primary-500 mr-2"></i>Your Account Credentials
      </h3>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Copy and store these credentials securely.</p>
      <% deliveredItems.forEach(function(item) { %>
        <% item.deliveredAccounts.forEach(function(account) { %>
          <div class="bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4 mb-2 last:mb-0">
            <pre class="font-mono text-sm text-gray-800 dark:text-gray-200 whitespace-pre-wrap break-all"><%= typeof account === 'string' ? account : JSON.stringify(account, null, 2) %></pre>
          </div>
        <% }); %>
      <% }); %>
    </div>
  <% } %>

  <!-- Action Buttons -->
  <div class="flex items-center justify-center gap-4">
    <a href="/user/orders" class="btn-primary py-3 px-6">
      <i class="fas fa-list mr-2"></i>View Orders
    </a>
    <a href="/shop" class="btn-secondary py-3 px-6">
      <i class="fas fa-store mr-2"></i>Continue Shopping
    </a>
  </div>
</div>
