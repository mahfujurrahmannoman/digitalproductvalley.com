<header class="fixed top-0 left-0 lg:left-64 right-0 h-16 bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 z-30 flex items-center justify-between px-4">
  <div class="flex items-center gap-3">
    <button id="sidebarToggle" class="lg:hidden p-2 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg">
      <i class="fas fa-bars"></i>
    </button>
    <h1 class="text-lg font-semibold text-gray-800 dark:text-gray-200"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></h1>
  </div>
  <div class="flex items-center gap-3">
    <a href="/user/notifications" class="relative p-2 text-gray-600 dark:text-gray-300 hover:text-primary-500">
      <i class="fas fa-bell"></i>
      <% if (notificationCount > 0) { %>
        <span class="absolute -top-1 -right-1 bg-red-500 text-white text-xs rounded-full w-4 h-4 flex items-center justify-center"><%= notificationCount %></span>
      <% } %>
    </a>
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 bg-primary-500 rounded-full flex items-center justify-center text-white text-sm font-medium">
        <%= user.username.charAt(0).toUpperCase() %>
      </div>
      <span class="hidden sm:inline text-sm font-medium text-gray-700 dark:text-gray-200"><%= user.username %></span>
    </div>
  </div>
</header>
