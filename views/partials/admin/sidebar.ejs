<aside id="adminSidebar" class="fixed left-0 top-0 h-full w-64 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 z-40 transform -translate-x-full lg:translate-x-0 transition-transform duration-200">
  <div class="p-4 border-b border-gray-200 dark:border-gray-700">
    <a href="/admin" class="text-xl font-bold text-primary-500"><%= siteSettings.siteName %></a>
    <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Admin Panel</p>
  </div>

  <nav class="p-3 space-y-1 overflow-y-auto" style="height: calc(100% - 80px);">
    <a href="/admin" class="sidebar-link <%= currentPath === '/admin' ? 'active' : '' %>">
      <i class="fas fa-chart-line w-5"></i> Dashboard
    </a>
    <a href="/admin/users" class="sidebar-link <%= currentPath.startsWith('/admin/users') ? 'active' : '' %>">
      <i class="fas fa-users w-5"></i> Users
    </a>
    <a href="/admin/suppliers" class="sidebar-link <%= currentPath.startsWith('/admin/suppliers') ? 'active' : '' %>">
      <i class="fas fa-building w-5"></i> Suppliers
    </a>
    <a href="/admin/categories" class="sidebar-link <%= currentPath.startsWith('/admin/categories') ? 'active' : '' %>">
      <i class="fas fa-folder w-5"></i> Categories
    </a>
    <a href="/admin/products" class="sidebar-link <%= currentPath.startsWith('/admin/products') ? 'active' : '' %>">
      <i class="fas fa-box w-5"></i> Products
    </a>
    <a href="/admin/orders" class="sidebar-link <%= currentPath.startsWith('/admin/orders') ? 'active' : '' %>">
      <i class="fas fa-shopping-cart w-5"></i> Orders
    </a>
    <a href="/admin/payments" class="sidebar-link <%= currentPath.startsWith('/admin/payments') ? 'active' : '' %>">
      <i class="fas fa-credit-card w-5"></i> Payments
    </a>
    <a href="/admin/withdrawals" class="sidebar-link <%= currentPath.startsWith('/admin/withdrawals') ? 'active' : '' %>">
      <i class="fas fa-money-bill-wave w-5"></i> Withdrawals
    </a>
    <a href="/admin/support" class="sidebar-link <%= currentPath.startsWith('/admin/support') ? 'active' : '' %>">
      <i class="fas fa-headset w-5"></i> Support
    </a>
    <a href="/admin/blog" class="sidebar-link <%= currentPath.startsWith('/admin/blog') ? 'active' : '' %>">
      <i class="fas fa-newspaper w-5"></i> Blog
    </a>
    <a href="/admin/api-keys" class="sidebar-link <%= currentPath.startsWith('/admin/api-keys') ? 'active' : '' %>">
      <i class="fas fa-key w-5"></i> API Keys
    </a>
    <a href="/admin/settings" class="sidebar-link <%= currentPath.startsWith('/admin/settings') ? 'active' : '' %>">
      <i class="fas fa-cog w-5"></i> Settings
    </a>

    <hr class="border-gray-200 dark:border-gray-700 my-3">
    <a href="/" class="sidebar-link">
      <i class="fas fa-external-link-alt w-5"></i> View Site
    </a>
    <a href="/auth/logout" class="sidebar-link text-red-500">
      <i class="fas fa-sign-out-alt w-5"></i> Logout
    </a>
  </nav>
</aside>
