<!-- Footer -->
<footer class="bg-white border-t border-gray-200 mt-12">
  <div class="max-w-7xl mx-auto px-4 py-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand & Support -->
      <div>
        <div class="mb-4">
          <% if (siteSettings.logo) { %>
            <img src="<%= siteSettings.logo %>" alt="<%= siteSettings.siteName %>" class="h-10 mb-3">
          <% } else { %>
            <span class="text-2xl font-bold tracking-tight">
              <span class="text-gray-800">ACCS</span><span class="text-primary-500">Z</span><span class="text-gray-800">ONE</span>
            </span>
          <% } %>
        </div>
        <h4 class="font-semibold text-gray-800 mb-3">Customer Support</h4>
        <a href="/support/new" class="inline-flex items-center gap-2 bg-primary-500 hover:bg-primary-600 text-white text-sm font-medium py-2 px-4 rounded transition-colors mb-2">
          <i class="fas fa-pen"></i> New Ticket / Ask a Question
        </a>
        <br>
        <% if (!user || user.role === 'customer') { %>
          <a href="/supplier/apply" class="inline-flex items-center gap-2 bg-pink-500 hover:bg-pink-600 text-white text-sm font-medium py-2 px-4 rounded transition-colors mt-2">
            <i class="fas fa-user-plus"></i> Become a Supplier
          </a>
        <% } %>
      </div>

      <!-- Useful Links -->
      <div>
        <h4 class="font-semibold text-gray-800 mb-4">Useful Links</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/" class="text-gray-600 hover:text-primary-500 transition-colors"><i class="fas fa-chevron-right text-xs text-gray-400 mr-1"></i> Home</a></li>
          <li><a href="/pages/about" class="text-gray-600 hover:text-primary-500 transition-colors"><i class="fas fa-chevron-right text-xs text-gray-400 mr-1"></i> About Us</a></li>
          <li><a href="/shop" class="text-gray-600 hover:text-primary-500 transition-colors"><i class="fas fa-chevron-right text-xs text-gray-400 mr-1"></i> All Accounts</a></li>
          <li><a href="/pages/terms" class="text-gray-600 hover:text-primary-500 transition-colors"><i class="fas fa-chevron-right text-xs text-gray-400 mr-1"></i> Terms</a></li>
          <li><a href="/pages/api-docs" class="text-gray-600 hover:text-primary-500 transition-colors"><i class="fas fa-chevron-right text-xs text-gray-400 mr-1"></i> API Documentation - Reseller Program</a></li>
          <li><a href="/supplier/apply" class="text-gray-600 hover:text-primary-500 transition-colors"><i class="fas fa-chevron-right text-xs text-gray-400 mr-1"></i> Supplier Register</a></li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h4 class="font-semibold text-gray-800 mb-4">Subscribe to Newsletter</h4>
        <p class="text-sm text-gray-500 mb-4">Stay updated with our latest offers and news</p>
        <form class="flex gap-0">
          <div class="flex items-center bg-primary-500 text-white px-3 rounded-l">
            <i class="fas fa-envelope"></i>
          </div>
          <input type="email" placeholder="Enter Your Email..." class="flex-1 px-3 py-2.5 border border-gray-300 border-l-0 text-sm outline-none focus:ring-1 focus:ring-primary-500">
          <button type="submit" class="bg-primary-500 hover:bg-primary-600 text-white px-4 py-2.5 rounded-r text-sm font-medium transition-colors">
            <i class="fas fa-paper-plane mr-1"></i> Subscribe
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-gray-200 py-4">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between text-xs text-gray-500">
      <span>&copy; <%= new Date().getFullYear() %> <%= siteSettings.siteName %>. All rights reserved.</span>
    </div>
  </div>
</footer>
