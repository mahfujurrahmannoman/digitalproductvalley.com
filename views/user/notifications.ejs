<!-- Breadcrumb -->
<div class="max-w-7xl mx-auto px-4 pt-6 pb-2">
  <nav class="text-sm text-gray-500 mb-4">
    <a href="/" class="hover:text-primary-500">Home</a>
    <span class="mx-1">/</span>
    <span class="text-gray-700 font-medium">Notifications</span>
  </nav>
  <h1 class="text-2xl font-bold text-gray-800">Hello, <span class="text-primary-500"><%= user.username.toUpperCase() %></span></h1>
</div>

<!-- 2-Column Layout -->
<div class="max-w-7xl mx-auto px-4 py-6">
  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
    <!-- Left Sidebar -->
    <div class="col-span-1">
      <% const walletBalance = 0; const currentPage = 'notifications'; %>
      <%- include('../partials/user-sidebar') %>
    </div>

    <!-- Right Content -->
    <div class="lg:col-span-3">
      <div class="card">
        <div class="p-4 border-b border-gray-200 flex items-center justify-between">
          <div>
            <h3 class="font-semibold text-primary-500 text-lg">Notifications</h3>
            <p class="text-sm text-gray-500"><%= pagination.total %> total notification<%= pagination.total !== 1 ? 's' : '' %></p>
          </div>
          <% if (notifications.length > 0) { %>
            <form action="/user/notifications/read-all" method="POST">
              <button type="submit" class="btn-secondary text-sm">
                <i class="fas fa-check-double mr-1"></i> Mark All as Read
              </button>
            </form>
          <% } %>
        </div>

        <% if (notifications.length === 0) { %>
          <div class="p-12 text-center">
            <i class="fas fa-bell-slash text-5xl text-gray-300 mb-4"></i>
            <h3 class="text-lg font-medium text-gray-700 mb-2">No notifications</h3>
            <p class="text-gray-500">You're all caught up!</p>
          </div>
        <% } else { %>
          <div class="divide-y divide-gray-100">
            <% notifications.forEach(function(notif) { %>
              <div class="p-4 flex items-start gap-3 <%= !notif.isRead ? 'bg-orange-50 border-l-4 border-l-primary-500' : '' %>">
                <div class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center
                  <% if (notif.type === 'order_delivered' || notif.type === 'deposit_success' || notif.type === 'withdrawal_approved' || notif.type === 'supplier_approved') { %>
                    bg-green-100 text-green-500
                  <% } else if (notif.type === 'order_cancelled' || notif.type === 'withdrawal_rejected') { %>
                    bg-red-100 text-red-500
                  <% } else if (notif.type === 'stock_low') { %>
                    bg-yellow-100 text-yellow-500
                  <% } else { %>
                    bg-blue-100 text-blue-500
                  <% } %>
                ">
                  <% if (notif.type === 'order_placed' || notif.type === 'order_delivered' || notif.type === 'order_cancelled' || notif.type === 'new_sale') { %>
                    <i class="fas fa-shopping-bag"></i>
                  <% } else if (notif.type === 'deposit_success' || notif.type === 'withdrawal_approved' || notif.type === 'withdrawal_rejected') { %>
                    <i class="fas fa-wallet"></i>
                  <% } else if (notif.type === 'ticket_reply') { %>
                    <i class="fas fa-headset"></i>
                  <% } else if (notif.type === 'stock_low') { %>
                    <i class="fas fa-exclamation-triangle"></i>
                  <% } else { %>
                    <i class="fas fa-bell"></i>
                  <% } %>
                </div>
                <div class="flex-1 min-w-0">
                  <% if (notif.link) { %><a href="<%= notif.link %>" class="block"><% } %>
                    <p class="text-sm font-medium text-gray-800"><%= notif.title %></p>
                    <p class="text-sm text-gray-500 mt-1"><%= notif.message %></p>
                    <p class="text-xs text-gray-400 mt-1"><%= helpers.formatDateTime(notif.createdAt) %></p>
                  <% if (notif.link) { %></a><% } %>
                </div>
                <% if (!notif.isRead) { %>
                  <span class="w-2 h-2 rounded-full bg-primary-500 flex-shrink-0 mt-2"></span>
                <% } %>
              </div>
            <% }); %>
          </div>

          <%- include('../partials/pagination') %>
        <% } %>
      </div>
    </div>
  </div>
</div>
