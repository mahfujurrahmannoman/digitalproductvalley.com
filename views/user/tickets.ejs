<!-- Breadcrumb -->
<div class="max-w-7xl mx-auto px-4 pt-6 pb-2">
  <nav class="text-sm text-gray-500 mb-4">
    <a href="/" class="hover:text-primary-500">Home</a>
    <span class="mx-1">/</span>
    <span class="text-gray-700 font-medium">Tickets</span>
  </nav>
  <h1 class="text-2xl font-bold text-gray-800">Hello, <span class="text-primary-500"><%= user.username.toUpperCase() %></span></h1>
</div>

<!-- 2-Column Layout -->
<div class="max-w-7xl mx-auto px-4 py-6">
  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
    <!-- Left Sidebar -->
    <div class="col-span-1">
      <% const walletBalance = 0; const currentPage = 'tickets'; %>
      <%- include('../partials/user-sidebar') %>
    </div>

    <!-- Right Content -->
    <div class="lg:col-span-3">
      <div class="card">
        <div class="p-4 border-b border-gray-200 flex items-center justify-between">
          <h3 class="font-semibold text-primary-500 text-lg">Tickets</h3>
          <a href="/support/new" class="btn-primary text-sm">
            <i class="fas fa-plus mr-1"></i> New ticket / Ask a question
          </a>
        </div>

        <!-- Tabs -->
        <div class="border-b border-gray-200">
          <div class="flex" id="ticket-tabs">
            <button
              type="button"
              class="px-6 py-3 text-sm font-medium border-b-2 border-primary-500 text-primary-500 tab-btn active"
              data-tab="open"
              onclick="switchTab('open')"
            >
              Open Tickets
            </button>
            <button
              type="button"
              class="px-6 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 tab-btn"
              data-tab="closed"
              onclick="switchTab('closed')"
            >
              Closed Tickets
            </button>
          </div>
        </div>

        <% if (tickets.length === 0) { %>
          <div class="p-12 text-center">
            <i class="fas fa-tag text-5xl text-gray-300 mb-4"></i>
            <h3 class="text-lg font-medium text-gray-700 mb-2">No tickets yet</h3>
            <p class="text-gray-500 mb-4">Need help? Open a new ticket.</p>
            <a href="/support/new" class="btn-primary">
              <i class="fas fa-plus mr-1"></i> Ask a question
            </a>
          </div>
        <% } else { %>
          <!-- Open Tickets -->
          <div id="tab-open" class="tab-content">
            <%
              const openTickets = tickets.filter(t => t.status !== 'resolved' && t.status !== 'closed');
            %>
            <% if (openTickets.length === 0) { %>
              <div class="p-8 text-center text-gray-500">
                <p>No open tickets</p>
              </div>
            <% } else { %>
              <div class="table-container" style="border:none;">
                <table class="w-full">
                  <thead>
                    <tr>
                      <th>Ticket #</th>
                      <th>Subject</th>
                      <th>Status</th>
                      <th>Priority</th>
                      <th>Last Updated</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% openTickets.forEach(function(t) { %>
                      <tr>
                        <td class="font-mono text-sm text-gray-500"><%= t.ticketNumber %></td>
                        <td class="font-medium text-gray-800"><%= helpers.truncate(t.subject, 40) %></td>
                        <td>
                          <% if (t.status === 'open') { %>
                            <span class="badge-warning">Open</span>
                          <% } else if (t.status === 'awaiting_reply') { %>
                            <span class="badge-info">Awaiting Reply</span>
                          <% } else { %>
                            <span class="badge-info"><%= t.status.replace(/_/g, ' ') %></span>
                          <% } %>
                        </td>
                        <td>
                          <% if (t.priority === 'high') { %>
                            <span class="badge-danger">High</span>
                          <% } else if (t.priority === 'medium') { %>
                            <span class="badge-warning">Medium</span>
                          <% } else { %>
                            <span class="badge-info">Low</span>
                          <% } %>
                        </td>
                        <td class="text-gray-500 text-sm"><%= helpers.formatDate(t.updatedAt) %></td>
                        <td>
                          <a href="/support/<%= t._id %>" class="text-primary-500 hover:text-primary-600 text-sm font-medium">
                            View <i class="fas fa-arrow-right ml-1"></i>
                          </a>
                        </td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>

          <!-- Closed Tickets -->
          <div id="tab-closed" class="tab-content" style="display:none;">
            <%
              const closedTickets = tickets.filter(t => t.status === 'resolved' || t.status === 'closed');
            %>
            <% if (closedTickets.length === 0) { %>
              <div class="p-8 text-center text-gray-500">
                <p>No closed tickets</p>
              </div>
            <% } else { %>
              <div class="table-container" style="border:none;">
                <table class="w-full">
                  <thead>
                    <tr>
                      <th>Ticket #</th>
                      <th>Subject</th>
                      <th>Status</th>
                      <th>Last Updated</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% closedTickets.forEach(function(t) { %>
                      <tr>
                        <td class="font-mono text-sm text-gray-500"><%= t.ticketNumber %></td>
                        <td class="font-medium text-gray-800"><%= helpers.truncate(t.subject, 40) %></td>
                        <td>
                          <span class="badge-success"><%= t.status === 'resolved' ? 'Resolved' : 'Closed' %></span>
                        </td>
                        <td class="text-gray-500 text-sm"><%= helpers.formatDate(t.updatedAt) %></td>
                        <td>
                          <a href="/support/<%= t._id %>" class="text-primary-500 hover:text-primary-600 text-sm font-medium">
                            View <i class="fas fa-arrow-right ml-1"></i>
                          </a>
                        </td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
  function switchTab(tab) {
    // Hide all tab content
    document.querySelectorAll('.tab-content').forEach(el => el.style.display = 'none');
    // Remove active from all buttons
    document.querySelectorAll('.tab-btn').forEach(el => {
      el.classList.remove('active', 'border-primary-500', 'text-primary-500');
      el.classList.add('border-transparent', 'text-gray-500');
    });
    // Show selected tab
    document.getElementById('tab-' + tab).style.display = 'block';
    // Activate button
    const btn = document.querySelector('.tab-btn[data-tab="' + tab + '"]');
    btn.classList.add('active', 'border-primary-500', 'text-primary-500');
    btn.classList.remove('border-transparent', 'text-gray-500');
  }
  // Initialize first tab as active
  document.querySelector('.tab-btn.active').classList.add('border-primary-500', 'text-primary-500');
</script>
