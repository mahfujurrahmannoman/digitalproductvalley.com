<div class="mb-6">
  <a href="/admin/categories" class="text-sm text-gray-500 hover:text-primary-600"><i class="fas fa-arrow-left mr-1"></i> Back to Categories</a>
  <h1 class="text-2xl font-bold text-gray-800 dark:text-white mt-2"><%= category ? 'Edit Category' : 'Create Category' %></h1>
</div>

<div class="card p-6 max-w-2xl">
  <form method="POST" action="<%= category ? '/admin/categories/' + category._id : '/admin/categories' %>">
    <div class="space-y-4">
      <div>
        <label class="label">Category Name *</label>
        <input type="text" name="name" value="<%= category ? category.name : '' %>" class="input-field" required>
      </div>

      <div>
        <label class="label">Parent Category</label>
        <select name="parent" class="input-field">
          <option value="">None (Top Level)</option>
          <% parents.forEach(p => { %>
          <option value="<%= p._id %>" <%= category && category.parent && category.parent.toString() === p._id.toString() ? 'selected' : '' %>><%= p.name %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label class="label">Icon (Font Awesome class)</label>
        <input type="text" name="icon" value="<%= category ? (category.icon || '') : '' %>" placeholder="fas fa-gamepad" class="input-field">
        <p class="text-xs text-gray-400 mt-1">E.g. fas fa-gamepad, fas fa-envelope</p>
      </div>

      <div>
        <label class="label">Description</label>
        <textarea name="description" rows="3" class="input-field"><%= category ? (category.description || '') : '' %></textarea>
      </div>

      <div>
        <label class="label">Sort Order</label>
        <input type="number" name="sortOrder" value="<%= category ? category.sortOrder : 0 %>" class="input-field">
      </div>

      <div class="flex items-center gap-2">
        <input type="checkbox" name="isActive" id="isActive" <%= !category || category.isActive ? 'checked' : '' %> class="w-4 h-4 text-primary-600 rounded">
        <label for="isActive" class="text-sm text-gray-700 dark:text-gray-300">Active</label>
      </div>

      <div class="flex gap-3 pt-4 border-t dark:border-gray-700">
        <button type="submit" class="btn-primary"><%= category ? 'Update Category' : 'Create Category' %></button>
        <a href="/admin/categories" class="btn-secondary">Cancel</a>
      </div>
    </div>
  </form>
</div>
