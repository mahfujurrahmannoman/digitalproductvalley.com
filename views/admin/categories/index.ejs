<div class="mb-6 flex items-center justify-between">
  <h1 class="text-2xl font-bold text-gray-800 dark:text-white">Category Management</h1>
  <a href="/admin/categories/create" class="btn-primary"><i class="fas fa-plus mr-1"></i> Add Category</a>
</div>

<div class="card p-5">
  <% if (tree.length === 0) { %>
  <p class="text-gray-400 text-center py-8">No categories yet. Create your first category.</p>
  <% } else { %>
  <div class="space-y-1">
    <% function renderTree(items, depth) { %>
      <% items.forEach(cat => { %>
      <div class="flex items-center justify-between p-3 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800/50" style="padding-left: <%= 12 + depth * 24 %>px;">
        <div class="flex items-center gap-3">
          <% if (depth > 0) { %>
          <i class="fas fa-level-up-alt fa-rotate-90 text-gray-300 text-xs"></i>
          <% } %>
          <% if (cat.icon) { %>
          <i class="<%= cat.icon %> text-gray-500"></i>
          <% } else { %>
          <i class="fas fa-folder text-yellow-500"></i>
          <% } %>
          <div>
            <span class="font-medium text-gray-800 dark:text-white"><%= cat.name %></span>
            <span class="text-xs text-gray-400 ml-2">/<%= cat.slug %></span>
          </div>
          <% if (!cat.isActive) { %>
          <span class="badge-warning text-xs">Inactive</span>
          <% } %>
          <span class="text-xs text-gray-400">(<%= cat.productCount %> products)</span>
        </div>
        <div class="flex items-center gap-2">
          <a href="/admin/categories/<%= cat._id %>/edit" class="btn-secondary text-xs px-2 py-1">
            <i class="fas fa-edit"></i> Edit
          </a>
          <form method="POST" action="/admin/categories/<%= cat._id %>/delete" onsubmit="return confirm('Delete this category?')">
            <button type="submit" class="btn-danger text-xs px-2 py-1">
              <i class="fas fa-trash"></i>
            </button>
          </form>
        </div>
      </div>
      <% if (cat.children && cat.children.length > 0) { renderTree(cat.children, depth + 1); } %>
      <% }) %>
    <% } %>
    <% renderTree(tree, 0) %>
  </div>
  <% } %>
</div>
