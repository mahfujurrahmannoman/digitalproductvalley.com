<div class="mb-6 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-800 dark:text-white">Stock Sync</h1>
    <p class="text-sm text-gray-500 mt-1">Auto-sync product stock from source supplier</p>
  </div>
  <form method="POST" action="/admin/stock-sync/trigger">
    <button type="submit" class="btn-primary" onclick="this.disabled=true;this.innerHTML='<i class=\'fas fa-spinner fa-spin mr-1\'></i> Syncing...';this.form.submit();">
      <i class="fas fa-sync-alt mr-1"></i> Sync Now
    </button>
  </form>
</div>

<!-- Status Card -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <div class="card p-5">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center">
        <i class="fas fa-clock text-blue-500"></i>
      </div>
      <div>
        <p class="text-xs text-gray-500">Last Sync</p>
        <p class="font-bold text-gray-800 dark:text-white text-sm">
          <% if (settings.stockSync && settings.stockSync.lastSyncAt) { %>
            <%= helpers.formatDateTime(settings.stockSync.lastSyncAt) %>
          <% } else { %>
            Never
          <% } %>
        </p>
      </div>
    </div>
  </div>
  <div class="card p-5">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
        <i class="fas fa-check-circle text-green-500"></i>
      </div>
      <div>
        <p class="text-xs text-gray-500">Products Updated</p>
        <p class="font-bold text-gray-800 dark:text-white text-sm">
          <%= settings.stockSync && settings.stockSync.lastSyncResult ? settings.stockSync.lastSyncResult.updated || 0 : 0 %>
        </p>
      </div>
    </div>
  </div>
  <div class="card p-5">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center">
        <i class="fas fa-link text-purple-500"></i>
      </div>
      <div>
        <p class="text-xs text-gray-500">Products Matched</p>
        <p class="font-bold text-gray-800 dark:text-white text-sm">
          <%= settings.stockSync && settings.stockSync.lastSyncResult ? settings.stockSync.lastSyncResult.matched || 0 : 0 %>
          / <%= settings.stockSync && settings.stockSync.lastSyncResult ? settings.stockSync.lastSyncResult.total || 0 : 0 %>
        </p>
      </div>
    </div>
  </div>
  <div class="card p-5">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg <%= settings.stockSync && settings.stockSync.enabled ? 'bg-green-100 dark:bg-green-900/30' : 'bg-gray-100 dark:bg-gray-700' %> flex items-center justify-center">
        <i class="fas fa-robot <%= settings.stockSync && settings.stockSync.enabled ? 'text-green-500' : 'text-gray-400' %>"></i>
      </div>
      <div>
        <p class="text-xs text-gray-500">Auto-Sync</p>
        <p class="font-bold text-sm <%= settings.stockSync && settings.stockSync.enabled ? 'text-green-600' : 'text-gray-500' %>">
          <%= settings.stockSync && settings.stockSync.enabled ? 'Enabled (' + (settings.stockSync.intervalMinutes || 30) + ' min)' : 'Disabled' %>
        </p>
      </div>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Settings -->
  <div>
    <div class="card p-6">
      <h2 class="text-lg font-semibold text-gray-800 dark:text-white mb-4"><i class="fas fa-cog mr-2 text-gray-400"></i>Sync Settings</h2>
      <form method="POST" action="/admin/stock-sync/settings">
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <div>
              <label class="font-medium text-sm text-gray-700 dark:text-gray-300">Enable Auto-Sync</label>
              <p class="text-xs text-gray-400">Automatically sync stock at interval</p>
            </div>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" name="syncEnabled" class="sr-only peer" <%= settings.stockSync && settings.stockSync.enabled ? 'checked' : '' %>>
              <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary-500"></div>
            </label>
          </div>
          <div>
            <label class="label">Sync Interval (minutes)</label>
            <input type="number" name="syncInterval" min="5" max="1440" value="<%= settings.stockSync ? settings.stockSync.intervalMinutes || 30 : 30 %>" class="input-field">
            <p class="text-xs text-gray-400 mt-1">Min: 5 min, Max: 1440 min (24h)</p>
          </div>
          <button type="submit" class="btn-primary w-full"><i class="fas fa-save mr-1"></i> Save Settings</button>
        </div>
      </form>
    </div>

    <!-- How It Works -->
    <div class="card p-6 mt-4">
      <h3 class="text-sm font-semibold text-gray-800 dark:text-white mb-3"><i class="fas fa-info-circle text-primary-500 mr-1"></i> How Stock Sync Works</h3>
      <ul class="text-xs text-gray-500 dark:text-gray-400 space-y-2">
        <li class="flex gap-2"><span class="text-primary-500 font-bold">1.</span> Fetches the supplier source page</li>
        <li class="flex gap-2"><span class="text-primary-500 font-bold">2.</span> Extracts all product titles and stock counts</li>
        <li class="flex gap-2"><span class="text-primary-500 font-bold">3.</span> Matches products to your local database by title</li>
        <li class="flex gap-2"><span class="text-primary-500 font-bold">4.</span> Updates stock counts for all matched products</li>
        <li class="flex gap-2"><span class="text-primary-500 font-bold">5.</span> Logs results for review</li>
      </ul>
      <div class="mt-3 p-3 bg-yellow-50 dark:bg-yellow-900/20 rounded text-xs text-yellow-700 dark:text-yellow-400">
        <i class="fas fa-exclamation-triangle mr-1"></i> Prices are NOT synced — only stock counts. Your 30% markup is preserved.
      </div>
    </div>
  </div>

  <!-- Sync History -->
  <div class="lg:col-span-2">
    <div class="card">
      <div class="p-5 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold text-gray-800 dark:text-white"><i class="fas fa-history mr-2 text-gray-400"></i>Sync History</h2>
      </div>
      <% if (syncLogs && syncLogs.length > 0) { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 dark:bg-gray-800">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Scraped</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Matched</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Updated</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Failed</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Duration</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Trigger</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
              <% syncLogs.forEach(function(log) { %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                <td class="px-4 py-3 text-gray-700 dark:text-gray-300 whitespace-nowrap"><%= helpers.formatDateTime(log.startedAt) %></td>
                <td class="px-4 py-3">
                  <% if (log.status === 'completed') { %>
                    <span class="badge-success">Completed</span>
                  <% } else if (log.status === 'failed') { %>
                    <span class="badge-danger">Failed</span>
                  <% } else { %>
                    <span class="badge-warning">Running</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-center font-medium"><%= log.totalScraped %></td>
                <td class="px-4 py-3 text-center font-medium text-purple-600"><%= log.totalMatched %></td>
                <td class="px-4 py-3 text-center font-medium text-green-600"><%= log.totalUpdated %></td>
                <td class="px-4 py-3 text-center font-medium <%= log.totalFailed > 0 ? 'text-red-600' : 'text-gray-400' %>"><%= log.totalFailed %></td>
                <td class="px-4 py-3 text-right text-gray-500"><%= log.duration ? (log.duration / 1000).toFixed(1) + 's' : '-' %></td>
                <td class="px-4 py-3 text-center">
                  <% if (log.triggeredBy === 'auto') { %>
                    <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full">Auto</span>
                  <% } else { %>
                    <span class="text-xs bg-gray-100 text-gray-700 px-2 py-0.5 rounded-full">Manual</span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="p-10 text-center text-gray-400">
          <i class="fas fa-sync-alt text-3xl mb-3"></i>
          <p class="font-medium">No sync history yet</p>
          <p class="text-sm mt-1">Click "Sync Now" to run your first stock sync</p>
        </div>
      <% } %>
    </div>
  </div>
</div>
